# Supabase project URL, for example: https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anon key (safe for client usage with RLS)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service role key (server-only, never expose to client)
SUPABASE_SERVICE_ROLE_KEY=

# Telegram bot token used for server-side verification of Mini App init data
TELEGRAM_BOT_TOKEN=

# Secret for signed app session cookie (long random value, server-only)
APP_SESSION_SECRET=
